# ─────────────────────────────────────────────────────
# dWallet Environment Variables
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────

# ── Blockchain RPC (for live balances) ───────────────
# Get a free key at https://infura.io
VITE_INFURA_KEY=your_infura_project_id_here

# OR use Alchemy — https://alchemy.com
VITE_ALCHEMY_ETH=your_alchemy_ethereum_key_here
VITE_ALCHEMY_POLYGON=your_alchemy_polygon_key_here

# ── WalletConnect v2 (required for dApp connections) ─
# Get a FREE Project ID at https://cloud.walletconnect.com
# Takes < 2 minutes — no credit card required
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ─── On Vercel ────────────────────────────────────────
# Add all of the above in:
# Project → Settings → Environment Variables
# They will be injected at build time as import.meta.env.VITE_*

# ── Already in v2/v3 ─────────────────────────────────────────────────
# VITE_INFURA_KEY=your_key          (enables live balances + DeFi txs)
# VITE_WALLETCONNECT_PROJECT_ID=... (enables WalletConnect)
#
# Without VITE_INFURA_KEY the DeFi panels work in preview/simulation mode
# with realistic mock quotes. Add the key to execute real transactions.
